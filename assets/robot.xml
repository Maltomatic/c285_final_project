<mujoco model="six_wheel_skidsteer">

  <option timestep="0.01" integrator="implicitfast" gravity="0 0 -9.81"/>


  <default>
    <joint damping="0.1" armature="0.01"/>
    <geom friction="1.0 0.005 0.001" condim="3" contype="1" conaffinity="1"/>
  </default>

  <asset>
    <texture name="grid" type="2d" builtin="checker"
             rgb1="0.85 0.85 0.85" rgb2="0.6 0.6 0.6"
             width="512" height="512"/>
    <material name="grid" texture="grid" texrepeat="5 5" reflectance="0.2"/>
    <material name="chassis_mat" rgba="0.2 0.4 0.8 1"/>
    <material name="wheel_mat"   rgba="0.15 0.15 0.15 1"/>
  </asset>

  <worldbody>

    <light diffuse="0.8 0.8 0.8" pos="0 0 10" dir="0 0 -1" castshadow="false"/>

    <!-- Ground plane -->
    <geom name="floor" type="plane" size="40 40 0.1" material="grid"
          contype="1" conaffinity="1"/>

    <!-- ─── Chassis ─────────────────────────────────────────────────── -->
    <!-- pos Z = wheel_radius(0.15) + chassis_half_height(0.10) = 0.25  -->
    <body name="chassis" pos="0 0 0.25">
      <freejoint name="chassis_joint"/>
      <geom name="chassis_geom" type="box" size="0.5 0.3 0.1"
            material="chassis_mat" mass="20"/>

      <!-- site at chassis centre for pose/velocity queries -->
      <site name="imu" pos="0 0 0" size="0.02"/>

      <!-- ─── Left wheels (y = +0.35) ─────────────────────────────── -->
      <!-- zaxis="0 1 0": align cylinder's long axis with world Y (sideways).
           size = "radius  half_width" = "0.15  0.04"
           Joint hinge axis="0 1 0" matches — both rotate around Y.         -->

      <body name="wheel_fl" pos=" 0.38  0.35 -0.10">
        <joint name="wheel_fl_joint" type="hinge" axis="0 1 0" limited="false"/>
        <geom  name="wheel_fl_geom" type="cylinder" size="0.15 0.04"
               zaxis="0 1 0" material="wheel_mat" mass="1.5"
               friction="0.8 0.005 0.001"/>
      </body>

      <body name="wheel_ml" pos=" 0.00  0.35 -0.10">
        <joint name="wheel_ml_joint" type="hinge" axis="0 1 0" limited="false"/>
        <geom  name="wheel_ml_geom" type="cylinder" size="0.15 0.04"
               zaxis="0 1 0" material="wheel_mat" mass="1.5"
               friction="0.8 0.005 0.001"/>
      </body>

      <body name="wheel_rl" pos="-0.38  0.35 -0.10">
        <joint name="wheel_rl_joint" type="hinge" axis="0 1 0" limited="false"/>
        <geom  name="wheel_rl_geom" type="cylinder" size="0.15 0.04"
               zaxis="0 1 0" material="wheel_mat" mass="1.5"
               friction="0.8 0.005 0.001"/>
      </body>

      <!-- ─── Right wheels (y = -0.35) ────────────────────────────── -->

      <body name="wheel_fr" pos=" 0.38 -0.35 -0.10">
        <joint name="wheel_fr_joint" type="hinge" axis="0 1 0" limited="false"/>
        <geom  name="wheel_fr_geom" type="cylinder" size="0.15 0.04"
               zaxis="0 1 0" material="wheel_mat" mass="1.5"
               friction="0.8 0.005 0.001"/>
      </body>

      <body name="wheel_mr" pos=" 0.00 -0.35 -0.10">
        <joint name="wheel_mr_joint" type="hinge" axis="0 1 0" limited="false"/>
        <geom  name="wheel_mr_geom" type="cylinder" size="0.15 0.04"
               zaxis="0 1 0" material="wheel_mat" mass="1.5"
               friction="0.8 0.005 0.001"/>
      </body>

      <body name="wheel_rr" pos="-0.38 -0.35 -0.10">
        <joint name="wheel_rr_joint" type="hinge" axis="0 1 0" limited="false"/>
        <geom  name="wheel_rr_geom" type="cylinder" size="0.15 0.04"
               zaxis="0 1 0" material="wheel_mat" mass="1.5"
               friction="0.8 0.005 0.001"/>
      </body>

    </body>
  </worldbody>

  <!-- ─── Velocity actuators ──────────────────────────────────────────
       ctrl[0] = wheel_fl  (front-left)
       ctrl[1] = wheel_ml  (mid-left)
       ctrl[2] = wheel_rl  (rear-left)
       ctrl[3] = wheel_fr  (front-right)
       ctrl[4] = wheel_mr  (mid-right)
       ctrl[5] = wheel_rr  (rear-right)
  ──────────────────────────────────────────────────────────────────── -->
  <actuator>
    <velocity name="act_fl" joint="wheel_fl_joint" kv="85"/>
    <velocity name="act_ml" joint="wheel_ml_joint" kv="85"/>
    <velocity name="act_rl" joint="wheel_rl_joint" kv="85"/>
    <velocity name="act_fr" joint="wheel_fr_joint" kv="85"/>
    <velocity name="act_mr" joint="wheel_mr_joint" kv="85"/>
    <velocity name="act_rr" joint="wheel_rr_joint" kv="85"/>
  </actuator>

</mujoco>
